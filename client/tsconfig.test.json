{
  "compilerOptions": {
    "target": "ES2022",
    "module": "es2022",
    "moduleResolution": "node",
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "types": ["vite/client", "jest", "@testing-library/jest-dom", "node"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true,

    "baseUrl": "./src",
    "paths": {
      "@features/*": ["app/features/*"],
      "@shared/*": ["shared/*"],
      "@/*": ["*"]
    }
  },
  "include": ["src"]
}
